# Usamos Node.js
FROM node:20-slim

WORKDIR /app

# Copiamos archivos de dependencias
COPY package.json package-lock.json* ./

# Instalamos dependencias
RUN npm install

# Copiamos el código
COPY . .

# Exponemos el puerto de Vite (usualmente 5173) o Next.js (3000)
EXPOSE 5173

# Comando para desarrollo
CMD ["npm", "run", "dev", "--", "--host"]